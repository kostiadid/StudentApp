{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "StudentApp",
    "Audience": "StudentAppClients",
    "Key": "DEMO_KEY11111111111111111111111111111111111111111111111111",
    "ExpiresMinutes": 60
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=Studentapp.db"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*"
}